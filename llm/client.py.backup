from llama_cpp import Llama
import os


MODEL_PATH = "models/model.gguf"


llm = None


def load_model():
    global llm
    if llm is None:
        llm = Llama(
            model_path=MODEL_PATH,
            n_ctx=2048,
            n_threads=4,   # M1 safe setting
            n_batch=128,
            verbose=False
        )
    return llm


def build_prompt(prompt):
    task = prompt["task"]["goal"]
    memory = prompt.get("memory", {})

    return f"""You are Hermes execution engine.

TASK:
{task}

MEMORY:
{memory}

RULES:
- be concise
- follow instruction exactly
- deterministic output"""


def call_model(prompt, route, config):
    if route != "local":
        return {"error": "cloud_not_enabled_in_m1_mode"}

    model = load_model()
    formatted = build_prompt(prompt)

    output = model(
        formatted,
        max_tokens=200,
        temperature=0.2,
        stop=["\n"]
    )

    text = output["choices"][0]["text"]

    return {
        "result": text.strip()
    }