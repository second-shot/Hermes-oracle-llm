{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIA Scoreboard",
  "type": "object",
  "required": [
    "tasks_completed",
    "proposals_created",
    "approvals_used",
    "blocked_unsafe_tasks",
    "errors",
    "safety_breaches",
    "uptime_ticks",
    "level"
  ],
  "properties": {
    "tasks_completed": {
      "type": "integer",
      "minimum": 0
    },
    "proposals_created": {
      "type": "integer",
      "minimum": 0
    },
    "approvals_used": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_unsafe_tasks": {
      "type": "integer",
      "minimum": 0
    },
    "tests_passed": {
      "type": "integer",
      "minimum": 0
    },
    "git_checkpoints_created": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "integer",
      "minimum": 0
    },
    "safety_breaches": {
      "type": "integer",
      "minimum": 0
    },
    "uptime_ticks": {
      "type": "integer",
      "minimum": 0
    },
    "value_generated_estimate": {
      "type": "integer",
      "minimum": 0
    },
    "level": {
      "type": "integer",
      "minimum": 0
    },
    "unlocked_bonuses": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
