{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIA Event JSONL Row",
  "type": "object",
  "required": [
    "timestamp",
    "event_type",
    "decision"
  ],
  "properties": {
    "timestamp": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "risk": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "approval_state": {
      "type": "string"
    },
    "result": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
