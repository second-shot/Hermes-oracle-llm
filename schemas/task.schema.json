{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIA Task Store",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "text",
      "status",
      "priority",
      "risk",
      "created_at",
      "updated_at",
      "proposal",
      "result"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^T-[0-9]{8}-[0-9]{6}$"
      },
      "text": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": [
          "new",
          "proposed",
          "approved",
          "working",
          "blocked",
          "complete"
        ]
      },
      "priority": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "risk": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      },
      "created_at": {
        "type": "string"
      },
      "updated_at": {
        "type": "string"
      },
      "proposal": {
        "type": "string"
      },
      "result": {
        "type": "string"
      }
    },
    "additionalProperties": true
  }
}
